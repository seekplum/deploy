Host *
#    UseKeychain yes
    AddKeysToAgent yes
    ForwardAgent yes
    ServerAliveInterval 3
    ServerAliveCountMax 20
    TCPKeepAlive no
    ControlMaster auto
#     ControlPath ~/.ssh/connection-%r@%h:%p
#     ControlPersist 4h
    Compression yes
    StrictHostKeyChecking no

# 开发机
Host ubuntu1
    HostName 192.168.1.4
    User root
    Port 22
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/seekplum

Host centos1
    HostName 192.168.1.7
    User root
    Port 22
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/seekplum

Host jump
    HostName console.i.jump.net
    User jump

Host master1
    HostName master1
    User root
    Port 22
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/seekplum
    ProxyJump jump

Host worker1
    HostName 192.168.1.8
    User root
    Port 22
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/seekplum
    ProxyJump master1


